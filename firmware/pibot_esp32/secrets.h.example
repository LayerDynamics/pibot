// Wi-Fi credentials for the PiBot ESP32 controller.
//
// Copy this file to `secrets.h` (same directory) and fill in your 2.4 GHz network.
// `secrets.h` is gitignored — your password is never committed.
//
//   cp secrets.h.example secrets.h
//   # then edit secrets.h
//
// The ESP32 radio is 2.4 GHz only; a 5 GHz-only SSID will not be found.
#pragma once

#define PIBOT_WIFI_SSID "your-2.4ghz-ssid"
#define PIBOT_WIFI_PASS "your-password"

// Optional: require a password for over-the-air (wireless) flashing. Leave this
// commented out for open OTA on your LAN; uncomment to lock it down.
// #define PIBOT_OTA_PASS "your-ota-password"
// #define PIBOT_OTA_HOST "pibot-esp32"   // mDNS name -> flash target pibot-esp32.local
